# Development Dockerfile for Next.js Frontend
# Build context should be the frontend directory
# docker build -f Dockerfile.dev -t pymes-frontend .

FROM node:22-alpine

WORKDIR /app

# Install pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate && pnpm config set ignore-scripts true

# Copy package files first (layer caching)
COPY package.json ./

# Install dependencies (no lockfile present)
RUN pnpm install --ignore-scripts

# Copy the rest of the source code
COPY . .

# Environment variables (overridable at runtime)
ENV NEXTAUTH_URL=http://localhost:3001
ENV NEXTAUTH_SECRET=dev-secret-change-in-production
ENV NEXT_PUBLIC_API_URL=http://localhost:3000
ENV PORT=3001

# Expose port
EXPOSE 3001

# Start development server with hot reload
CMD ["pnpm", "dev"]
